{
  "version": 1,
  "provider": {
    "name": "openrouter",
    "secret_ref": "provider.openrouter.api_key",
    "model": "anthropic/claude-sonnet-4-5"
  },
  "messaging": {
    "telegram": {
      "enabled": false,
      "secret_ref": "messaging.telegram.bot_token"
    },
    "discord": {
      "enabled": false,
      "secret_ref": "messaging.discord.bot_token"
    }
  },
  "memory": {
    "enabled": true,
    "backend": "sqlite"
  },
  "tools": {
    "web_search": false,
    "browser": false,
    "terminal": false
  },
  "desktop": {
    "enabled": true,
    "allowed_paths": ["."]
  }
}
